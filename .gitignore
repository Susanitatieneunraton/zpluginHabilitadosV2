dist/
build/
mta_archives/
gen/

# Archivos temporales de BAS/VSCode
.vscode/
.idea/
*.code-workspace

# Archivos del sistema
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-error.log*
*.log

# Archivos de pruebas locales
coverage/
*.lcov

# Configuración sensible o generada en BAS
.default-env.json
*.env
.env.*

# Archivos de despliegue generados
*.mtar
.mtar

# SAP specific
